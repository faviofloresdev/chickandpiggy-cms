# Server
HOST=0.0.0.0
PORT=1337

# Secrets
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Database
DATABASE_CLIENT=sqlite
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_FILENAME=.tmp/data.db
JWT_SECRET=tobemodified

# Stripe
STRIPE_SECRET_KEY=
CLIENT_URL=http://localhost:3000
STRAPI_STRIPE_CHECKOUT_PATH=/api/stripe/checkout
STRIPE_WEBHOOK_SECRET=

# Shipping
USE_CARRIER_MOCKS=false
SHIPPING_ORIGIN_LABEL=Los Angeles, CA
SHIPPING_ORIGIN_ADDRESS_LINE_1=
SHIPPING_ORIGIN_ADDRESS_LINE_2=
SHIPPING_ORIGIN_CITY=Los Angeles
SHIPPING_ORIGIN_STATE=CA
SHIPPING_ORIGIN_POSTAL=90001
SHIPPING_ORIGIN_COUNTRY=US
CARRIER_HTTP_TIMEOUT_MS=15000
CARRIER_HTTP_MAX_RETRIES=2
CARRIER_HTTP_RETRY_BASE_MS=300
SHIPPING_RATE_CACHE_TTL_MS=1800000
SHIPPING_METADATA_CACHE_TTL_MS=86400000
SHIPPING_LABEL_PROVIDER=shippo
REDIS_URL=
REDIS_CONNECT_TIMEOUT_MS=1000

# Cloudflare R2 media storage
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=
CF_R2_ENDPOINT=
CF_R2_REGION=auto
CF_R2_PUBLIC_URL=
CF_R2_ROOT_PATH=

# Default parcel fallback
DEFAULT_PACKAGE_WEIGHT_LB=1
DEFAULT_PACKAGE_LENGTH_IN=10
DEFAULT_PACKAGE_WIDTH_IN=8
DEFAULT_PACKAGE_HEIGHT_IN=4

# FedEx
FEDEX_USE_SANDBOX=true
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_CHILD_KEY=
FEDEX_CHILD_SECRET=

# UPS
UPS_USE_SANDBOX=true
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_MERCHANT_ID=

# USPS
USPS_USE_SANDBOX=true
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
USPS_CRID=
