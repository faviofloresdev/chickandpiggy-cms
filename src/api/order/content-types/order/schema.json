{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Persisted orders created during checkout"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "paymentIntentId": {
      "type": "string"
    },
    "clientSecret": {
      "type": "string"
    },
    "paymentStatus": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "paid",
        "failed",
        "cancelled"
      ],
      "default": "pending"
    },
    "currency": {
      "type": "string",
      "default": "usd"
    },
    "discountCode": {
      "type": "string"
    },
    "discountAmount": {
      "type": "decimal",
      "default": 0
    },
    "discountSnapshot": {
      "type": "json"
    },
    "subtotal": {
      "type": "decimal",
      "default": 0
    },
    "taxableSubtotal": {
      "type": "decimal",
      "default": 0
    },
    "taxAmount": {
      "type": "decimal",
      "default": 0
    },
    "shippingAmount": {
      "type": "decimal",
      "default": 0
    },
    "totalAmount": {
      "type": "decimal",
      "default": 0
    },
    "totals": {
      "type": "json"
    },
    "items": {
      "type": "json"
    },
    "customerName": {
      "type": "string"
    },
    "customerEmail": {
      "type": "email"
    },
    "customerPhone": {
      "type": "string"
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "orders"
    },
    "shippingAddress": {
      "type": "json"
    },
    "billingAddress": {
      "type": "json"
    },
    "shippingOptionId": {
      "type": "string"
    },
    "shippingOption": {
      "type": "json"
    },
    "discount": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::discount.discount",
      "inversedBy": "orders"
    },
    "metadata": {
      "type": "json"
    },
    "paidAt": {
      "type": "datetime"
    },
    "order_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    }
  }
}
