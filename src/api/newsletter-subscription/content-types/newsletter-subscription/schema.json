{
  "kind": "collectionType",
  "collectionName": "newsletter_subscriptions",
  "info": {
    "singularName": "newsletter-subscription",
    "pluralName": "newsletter-subscriptions",
    "displayName": "Newsletter Subscription"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "subscribed",
        "unsubscribed"
      ],
      "required": true,
      "default": "subscribed"
    },
    "source": {
      "type": "string",
      "required": true
    },
    "subscribedAt": {
      "type": "datetime"
    },
    "notes": {
      "type": "text"
    }
  }
}
